[Transfer]
ProtectVersion=%w
AppStream=https://github.com/Damillora/aemeath/raw/refs/heads/main/com.damillora.aemeath.metainfo.xml
Verify=false

[Source]
Type=url-file
Path=https://aemeath-dl.nanao.moe/os/updates/
MatchPattern=usr_@v_@u.verity.xz

[Target]
Type=partition
Path=auto
MatchPattern=aemeath_usr_verity_@v
MatchPartitionType=usr-verity
ReadOnly=true
PartitionFlags=0
